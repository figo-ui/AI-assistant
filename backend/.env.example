DJANGO_SECRET_KEY=change-me-use-50-plus-random-chars-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
REDIS_URL=redis://127.0.0.1:6379/1
RQ_ANALYSIS_QUEUE=analysis

# PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=chat-bot
DB_USERNAME=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=localhost
DB_PORT=5432

GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_RADIUS_METERS=5000
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax

# Model artifact paths
TEXT_MODEL_PATH=backend/models/text_classifier.joblib
TFIDF_VECTORIZER_PATH=backend/models/tfidf_vectorizer.joblib
TEXT_LABELS_PATH=backend/models/text_labels.json
TEXT_SVD_PATH=backend/models/tfidf_svd.joblib
TRIAGE_LLM_ADAPTER_PATH=backend/models/triage_llm_adapter
TRIAGE_LLM_BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.3
USE_LLM_TRIAGE=false
LLM_FALLBACK_TO_CLASSICAL=true
IMAGE_MODEL_PATH=backend/models/skin_cnn.keras
IMAGE_TORCH_MODEL_PATH=backend/models/skin_cnn_torch.pt
IMAGE_LABELS_PATH=backend/models/image_labels.json
IMAGE_INPUT_SIZE=224

# Dialogue style artifacts (optional; improves conversational tone)
DIALOGUE_INTENT_MODEL_PATH=backend/models/dialogue_intent_classifier.joblib
DIALOGUE_INTENT_VECTORIZER_PATH=backend/models/dialogue_intent_vectorizer.joblib
DIALOGUE_RESPONSE_TEMPLATES_PATH=backend/models/dialogue_response_templates.json
CASE_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=365
SSE_POLL_INTERVAL_SECONDS=1.5
SSE_MAX_WAIT_SECONDS=620
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_MINUTES=15

# Email (set to smtp for production; console prints to terminal in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@healthcare-ai.local
FRONTEND_BASE_URL=http://127.0.0.1:5173
